{
  "name": "bethoveen",
  "version": "0.1.0-pre",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "description": "Harness-agnostic Symphony port built on Bun, Effect.TS, and Ink. Orchestrates Linear issues into per-issue agent workspaces.",
  "bin": {
    "bethoveen": "./src/cli/main.tsx"
  },
  "scripts": {
    "dev": "bun src/cli/main.tsx run",
    "start": "bun src/cli/main.tsx run",
    "validate": "bun src/cli/main.tsx validate",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build --compile --target=bun --define 'process.env.DEV=\"false\"' --outfile dist/bethoveen src/cli/main.tsx"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@effect/platform": "^0.96.1",
    "@effect/platform-bun": "^0.89.0",
    "effect": "^3.21.2",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "liquidjs": "^10.16.0",
    "react": "^18.3.1",
    "yaml": "^2.5.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.3",
    "react-devtools-core": "^4",
    "typescript": "^5.5.4"
  }
}
